enterprise_analytics:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD') }}"
      role: "{{ env_var('SNOWFLAKE_ROLE', 'dbt_role') }}"
      database: "{{ env_var('SNOWFLAKE_DATABASE', 'ANALYTICS_DB') }}"
      warehouse: "{{ env_var('SNOWFLAKE_WAREHOUSE', 'ETL_WH') }}"
      schema: bronze
      threads: 4
    prod:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD') }}"
      role: dbt_role
      database: ANALYTICS_DB
      warehouse: ETL_WH
      schema: bronze
      threads: 8
