# Snowflake connection
DBT_DATABASE=ANALYTICS_DB
SNOWFLAKE_ACCOUNT=your_account.us-east-1
SNOWFLAKE_USER=dbt_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=dbt_role
SNOWFLAKE_WAREHOUSE=ETL_WH
SNOWFLAKE_DATABASE=ANALYTICS_DB
SNOWFLAKE_SCHEMA=bronze

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow

# Slack alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: email alerts
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_USER=kiranmayeelokam8@gmail.com
